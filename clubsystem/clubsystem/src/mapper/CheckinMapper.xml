<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clubsystem.mapper.CheckinMapper">

    <resultMap id="checkinResultMap" type="Checkin">
        <id column="id" property="id"/>
        <result column="signup_id" property="signupId"/>
        <result column="user_id" property="userId"/>
        <result column="activity_id" property="activityId"/>
        <result column="checkin_time" property="checkinTime"/>
        <result column="checkin_status" property="checkinStatus"/>
        <result column="operator_id" property="operatorId"/>
    </resultMap>

    <insert id="addCheckin" parameterType="Checkin" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO checkin (signup_id, user_id, activity_id, checkin_time, checkin_status, operator_id)
        VALUES (#{signupId}, #{userId}, #{activityId}, #{checkinTime}, #{checkinStatus}, #{operatorId})
    </insert>

    <select id="getCheckinsByActivityId" parameterType="int" resultMap="checkinResultMap">
        SELECT * FROM checkin WHERE activity_id = #{activityId} ORDER BY checkin_time DESC
    </select>

    <select id="getCheckinsByUserId" parameterType="int" resultMap="checkinResultMap">
        SELECT * FROM checkin WHERE user_id = #{userId} ORDER BY checkin_time DESC
    </select>

    <select id="getCheckinBySignupId" parameterType="int" resultMap="checkinResultMap">
        SELECT * FROM checkin WHERE signup_id = #{signupId}
    </select>

    <delete id="deleteCheckinsByActivityId" parameterType="int">
        DELETE FROM checkin WHERE activity_id = #{activityId}
    </delete>

    <delete id="deleteCheckinBySignupId" parameterType="int">
        DELETE FROM checkin WHERE signup_id = #{signupId}
    </delete>
</mapper>
