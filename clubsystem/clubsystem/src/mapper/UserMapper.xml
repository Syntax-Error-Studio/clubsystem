<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 用户数据访问层映射文件 -->
<mapper namespace="com.clubsystem.mapper.UserMapper">

    <!-- 定义 User 结果映射 -->
    <resultMap id="userResultMap" type="User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="real_name" property="realName"/>
        <result column="student_no" property="studentNo"/>
        <result column="phone" property="phone"/>
        <result column="role" property="role"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 新增用户 -->
    <insert id="addUser" parameterType="User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `user` (username, password, real_name, student_no, phone, role, create_time)
        VALUES (#{username}, #{password}, #{realName}, #{studentNo}, #{phone}, #{role}, #{createTime})
    </insert>

    <!-- 删除用户 -->
    <delete id="deleteUserById" parameterType="int">
        DELETE FROM `user` WHERE id = #{id}
    </delete>

    <!-- 查询所有用户 -->
    <select id="getAllUsers" resultMap="userResultMap">
        SELECT * FROM `user` ORDER BY create_time DESC
    </select>

    <!-- 根据ID查询用户 -->
    <select id="getUserById" parameterType="int" resultMap="userResultMap">
        SELECT * FROM `user` WHERE id = #{id}
    </select>

    <!-- 更新用户 -->
    <update id="updateUser" parameterType="User">
        UPDATE `user` SET
            username = #{username},
            password = #{password},
            real_name = #{realName},
            student_no = #{studentNo},
            phone = #{phone},
            role = #{role}
        WHERE id = #{id}
    </update>

    <!-- 根据用户名查询用户 -->
    <select id="getUserByUsername" parameterType="string" resultMap="userResultMap">
        SELECT * FROM `user` WHERE username = #{username}
    </select>

    <!-- 根据角色查询用户 -->
    <select id="getUsersByRole" parameterType="string" resultMap="userResultMap">
        SELECT * FROM `user` WHERE role = #{role} ORDER BY create_time DESC
    </select>

</mapper>

