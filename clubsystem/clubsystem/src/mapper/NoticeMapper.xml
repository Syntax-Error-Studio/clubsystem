<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.clubsystem.mapper.NoticeMapper">

    <resultMap id="noticeResultMap" type="Notice">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="content" property="content"/>
        <result column="publisher_id" property="publisherId"/>
        <result column="create_time" property="createTime"/>
        <result column="status" property="status"/>
    </resultMap>

    <insert id="addNotice" parameterType="Notice" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notice (title, content, publisher_id, create_time, status)
        VALUES (#{title}, #{content}, #{publisherId}, #{createTime}, #{status})
    </insert>

    <delete id="deleteNoticeById" parameterType="int">
        DELETE FROM notice WHERE id = #{id}
    </delete>

    <update id="updateNotice" parameterType="Notice">
        UPDATE notice SET title = #{title}, content = #{content}, status = #{status}
        WHERE id = #{id}
    </update>

    <select id="getAllNotices" resultMap="noticeResultMap">
        SELECT * FROM notice ORDER BY create_time DESC
    </select>

    <select id="getActiveNotices" resultMap="noticeResultMap">
        SELECT * FROM notice WHERE status = '有效' ORDER BY create_time DESC
    </select>

    <select id="getNoticeById" parameterType="int" resultMap="noticeResultMap">
        SELECT * FROM notice WHERE id = #{id}
    </select>
</mapper>
